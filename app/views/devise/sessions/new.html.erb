<div class="auth-container">
  <h2 class="auth-title">ログイン</h2>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    
    <div class="auth-field">
      <%= f.label :email, "メールアドレス" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input", placeholder: "example@mail.com" %>
    </div>

    <div class="auth-field">
      <%= f.label :password, "パスワード" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "form-input" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="auth-field" style="display: flex; align-items: center; gap: 10px;">
        <%= f.check_box :remember_me %>
        <%= f.label :remember_me, "次回から自動ログイン", style: "margin-bottom: 0; font-size: 0.9rem;" %>
      </div>
    <% end %>

    <div class="actions">
      <%= f.submit "ログインする", class: "btn-submit" %>
    </div>
  <% end %>

  <div class="auth-links">
    <%= render "devise/shared/links" %>
  </div>
</div>