<div class="auth-container">
  <h2 class="auth-title">パスワードの再設定</h2>
  
  <p style="color: #666; margin-bottom: 25px; font-size: 0.9rem;">
    ご登録のメールアドレスを入力してください。<br>再設定用のリンクをお送りします。
  </p>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
    <%# エラーメッセージ（共通パーツ）があれば表示 %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="auth-field">
      <%= f.label :email, "メールアドレス" %><br />
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input", placeholder: "example@mail.com" %>
    </div>

    <div class="actions">
      <%= f.submit "再設定メールを送信", class: "btn-submit" %>
    </div>
  <% end %>

  <div class="auth-links">
    <%= render "devise/shared/links" %>
  </div>
</div>