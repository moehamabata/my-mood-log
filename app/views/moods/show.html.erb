<div class="form-wrapper">
  <div class="form-container" style="max-width: 600px; margin-top: 50px;">
    
    <div class="show-header" style="text-align: center; margin-bottom: 30px;">
      <h1 style="color: #764ba2; font-size: 1.8rem; margin-bottom: 10px;">日記の詳細</h1>
      <p style="color: #888;"><%= @mood.created_at.strftime("%Y年%m月%d日 %H:%M") %></p>
    </div>

    <div class="mood-detail-card" style="background: #fdfdfd; padding: 30px; border-radius: 15px; border: 1px solid #eee; margin-bottom: 40px;">
      <div style="margin-bottom: 20px;">
        <span style="font-weight: bold; color: #333; display: block; margin-bottom: 5px;">気分：</span>
        <span class="mood-status-<%= @mood.feeling %>" style="display: inline-block; padding: 5px 20px; border-radius: 20px; background: #764ba2; color: white;">
          <%= @mood.feeling %>
        </span>
      </div>

      <div>
        <span style="font-weight: bold; color: #333; display: block; margin-bottom: 5px;">メモ：</span>
        <div style="line-height: 1.8; color: #555; white-space: pre-wrap;"><%= @mood.note %></div>
      </div>
    </div>

    <div class="show-actions" style="display: flex; flex-direction: column; gap: 15px;">
      <%= link_to "この日記を編集する", edit_mood_path(@mood), class: "btn-submit", style: "text-align: center; text-decoration: none;" %>
      
      <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px;">
        <%= link_to "← 一覧に戻る", moods_path, style: "color: #764ba2; text-decoration: none; font-weight: bold;" %>
        
        <%= link_to "削除", mood_path(@mood), 
            data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, 
            style: "color: #e74c3c; text-decoration: none; font-size: 0.9rem;" %>
      </div>
    </div>

  </div>
</div>