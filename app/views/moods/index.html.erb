<header class="main-header">
  <h1>My Mood Log</h1>
  <p>日々の感情を可視化する、あなただけの日記帳</p>
</header>

<div class="container">
  <%# --- 1. ボタン類を中央に寄せる --- %>
  <div class="centered-wrapper">
    <%= link_to '新しい日記を書く', new_mood_path, class: 'btn-new' %>
    
    <%# ログアウトボタン（Devise用） %>
    <%= button_to 'ログアウト', destroy_user_session_path, method: :delete, class: 'btn-logout-simple' %>
  </div>

  <hr class="section-divider">

  <%# --- 2. 日記がある場合とない場合の出し分け --- %>
  <% if @moods && @moods.any? %>
    <div class="diary-grid">
      <% @moods.each do |mood| %>
        <div class="diary-card">
          <div class="mood-bar mood-status-<%= mood.feeling %>">
            <%= mood.feeling %>
          </div>
          <div style="padding: 20px;">
            <h2 style="margin: 0 0 10px 0; font-size: 1.2rem;">
              <%= mood.created_at.strftime("%Y/%m/%d") %> の記録
            </h2>
            <p style="color: #666; font-size: 0.9rem;"><%= mood.note&.truncate(50) %></p>
            
            <div style="margin-top: 15px; border-top: 1px solid #eee; padding-top: 10px; font-size: 0.8rem; color: #999;">
              <%= mood.created_at.strftime("%H:%M") %> 投稿
            </div>
            <%= link_to "詳細を見る", mood_path(mood), style: "display: block; margin-top: 10px; color: #764ba2; text-decoration: none; font-weight: bold;" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <%# --- 3. 日記がない場合のメッセージを中央に --- %>
    <div class="centered-wrapper">
      <p style="font-size: 1.3rem; font-weight: bold; color: #764ba2;">まだ日記がありません。</p>
      <p style="color: #666; margin-bottom: 20px;">最初の１歩を書き出してみませんか？</p>
      <%= link_to '最初の日記を書く', new_mood_path, class: 'btn-new' %>
    </div>
    <%# --- 3. ログアウトボタン（一番下） --- %>
    <div class="centered-wrapper" style="margin-top: 60px; margin-bottom: 40px;">
      <hr style="width: 100px; border: 0; border-top: 1px solid #eee; margin-bottom: 20px;">
      <%= button_to 'ログアウト', destroy_user_session_path, method: :delete, class: 'btn-logout-simple' %>
    </div>
  </div>
  <% end %>
</div>