<div class="form-wrapper">
  <div class="form-container">
    <div class="form-header">
      <h2>✏️ 日記を編集する</h2>
      <p>内容を修正して、今の気持ちを再確認しましょう</p>
    </div>

    <%= render "form", post: @post %>
    <div class="form-actions">
      <%= link_to "キャンセルして戻る", posts_path, class: "btn-cancel" %>
    </div>
  </div>
</div>