<%= form_with(model: @post, local: true, class: "styled-form") do |f| %>
  
  <% if post.errors.any? %>
    <div style="color: red;">
      <p><%= post.errors.count %>件のエラーにより保存できませんでした。</p>
      <ul>
        <% post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  
  <div class="form-group">
    <%= f.label :title, "タイトル" %>
    <%= f.text_field :title, placeholder: "例：最高のランチに出会った", class: "form-input" %>
  </div>

  <div class="form-group">
    <%= f.label :mood, "今の気分は？" %>
    <%= f.select :mood, [
      ["✨ 楽しい", "楽しい"],
      ["🍀 幸せ", "幸せ"],
      ["☁️ 普通", "普通"],
      ["🔥 元気", "元気"],
      ["🌙 寂しい", "寂しい"],
      ["😢 悲しい", "悲しい"]
    ], { prompt: "選択してください" }, { class: "form-select" } %>
  </div>

  <div class="form-group">
    <%= f.label :content, "今日のできごと" %>
    <%= f.text_area :content, rows: 10, placeholder: "どんなことがありましたか？", class: "form-textarea" %>
  </div>

  <div class="form-actions">
    <%= f.submit "日記を保存する", class: "btn-submit" %>
  </div>
<% end %>