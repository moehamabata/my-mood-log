<%= form_with(model: @post, local: true, class: "styled-form") do |f| %>
  
  <%# エラー表示部分 %>
  <% if @post.errors.any? %>
    <div class="error-messages">
      <p>⚠️ <%= @post.errors.count %>件のエラーがあります</p>
      <ul>
        <% @post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# 入力欄の各ブロック %>
  <div class="form-group">
    <%= f.label :title, "タイトル" %>
    <%= f.text_field :title, placeholder: "例：最高のランチに出会った", class: "form-input" %>
  </div>

  <div class="form-group">
    <%= f.label :mood, "今の気分は？" %>
    <%= f.select :mood, Post.mood_options, { prompt: "選択してください" }, { class: "form-select" } %>
  </div>

  <div class="form-group">
    <%= f.label :content, "今日のできごと" %>
    <%= f.text_area :content, rows: 15, placeholder: "どんなことがありましたか？", class: "form-textarea" %>
  </div>

  <div class="form-actions">
    <%= f.submit "日記を保存する", class: "btn-submit" %>
  </div>
<% end %>