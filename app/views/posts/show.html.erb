<article class="post-detail">
  <div class="detail-header">
    <span class="date"><%= @post.created_at.strftime("%Y年 %m月 %d日") %></spam>
    <h1><%= @post.title %></h1>
  </div>

  <div class="detail-content">
    <%= simple_format(@post.content) %> </div>

  <div class="detail-footer">
    <%= link_to "編集する", edit_post_path(@post), class: "btn-edit" %>
    <%= link_to "戻る", posts_path, class: "btn-back" %>
  </div>
</article>