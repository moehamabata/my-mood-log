<div class="form-wrapper">
  <div class="form-container">
    <h1 class="form-title" style="text-align: center; color: #764ba2; margin-bottom: 40px; font-size: 2.2rem;">
      新しい日記を書く
    </h1>

    <%= render "form", post: @post %>

    <div class="form-actions" style="text-align: center; margin-top: 50px;">
      <%= link_to "一覧に戻る", posts_path, style: "color: #764ba2; text-decoration: none; font-weight: bold; font-size: 1.1rem;" %>
    </div>
  </div>
</div>