<div class="form-wrapper">
  <div class="form-container">
    <div class="form-header">
      <h2>📝 新しい日記</h2>
      <p>今の気持ちを言葉にしてみましょう</p>
    </div>

    <%= form_with(model: @post, local: true, class: "styled-form") do |f| %>
      <div class="form-group">
        <%= f.label :title, "タイトル" %>
        <%= f.text_field :title, placeholder: "例：最高のランチに出会った", class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :content, "今日のできごと" %>
        <%= f.text_area :content, rows: 10, placeholder: "どんなことがありましたか？", class: "form-textarea" %>
      </div>

      <div class="form-actions">
        <%= f.submit "日記を公開する", class: "btn-submit" %>
        <%= link_to "キャンセルして戻る", posts_path, class: "btn-cancel" %>
      </div>
    <% end %>
  </div>
</div>